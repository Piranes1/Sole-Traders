<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trader Zone</title>

    <!-- BOOTSTRAP LINK -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <!-- CSS LINK -->
    <link rel="stylesheet" href="/css/mystyle.css">

    <!-- BOOTSTRAP ICONS LINK -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- GOOGLE FONTS LINK -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Allerta+Stencil&family=Notable&display=swap" rel="stylesheet">
</head>

<body>
    <!-- STICKY HEADER USING BOOTSTRAP NAVBAR -->
    <header>
        <nav id="headBanner" class="navbar navbar-expand-lg sticky-top bg-warning">
            <!-- LOGO AND BUSINESS TITLE -->
            <div id="logoTitle" class="container-fluid">
                <a class="navbar-brand  fw-bold fst-italic" href="/index">
                    <img src="/images/workericon.png" alt="Logo" class="d-inline-block align-middle">
                    SOLE TRADERS
                </a>
                <!-- NAVBAR TOGGLER TO HIDE QUICK LINKS IN SMALL SCREENS FOR RESPONSIVENESS AND A BETTER UX - navbar-expand-lg LOGIC HIDES BUTTON IN LARGE SCREENS -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <!-- QUICK LINKS -->
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <div class="navbar-nav ms-auto">
                        <a class="nav-link" aria-current="page" href="/index">Home</a>
                        <a class="nav-link" href="/directory">Find a Trader!</a>
                        <!-- LOGIC TO MAKE THE TRADER ZONE LINK LEAD TO PROFILE IF LOGGED IN OR TO LOGIN IF NOT -->
                        <!-- LOGOUT BUTTON WILL ONLY SHOW IF LOGGED IN -->
                        <% if (loggedIn) { %>
                            <a class="nav-link active" href="/profile">
                                <%= trader_name %>'s Zone
                            </a>
                        <% } else { %>
                            <a class="nav-link active" href="/login">Trader Zone</a>
                        <% } %>
                        <!-- LOGOUT BUTTON WILL ONLY SHOW IF LOGGED IN -->   
                        <% if (loggedIn) { %>
                            <a class="nav-link" href="/logout">Logout</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main>
        <!-- CONTAINER WITH ONE CARD: ADD A SERVICE FORM -->
        <div class="container pt-5">
            <!-- CARD WITH SERVICES FORM -->
            <div class="row justify-content-center">
                <div class="col-md-10 col-lg-8">
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <h5 class="card-title text-center mb-4">Add a Service</h5>
                            <form action="" method="post">
                                <!-- Title -->
                                <div class="mb-3">
                                    <label for="title" class="form-label">Title</label>
                                    <input type="text" name="title" id="title" required
                                        class="form-control <%= (locals.errors && errors.find(e => e.path === 'title')) ? 'is-invalid' : '' %>"
                                        value="<%= locals.oldData ? oldData.title : '' %>"
                                        placeholder="e.g. Oven repair, fence building...">

                                    <% if (locals.errors) { %>
                                        <% let error = errors.find(e => e.path === 'title'); %>
                                        <% if (error) { %>
                                            <div class="invalid-feedback"><%= error.msg %></div>
                                        <% } %>
                                    <% } %>
                                </div>
                                <!-- Description -->
                                <div class="mb-3">
                                    <label for="description" class="form-label">Description</label>
                                    <textarea name="description" id="description"
                                            class="form-control <%= (locals.errors && errors.find(e => e.path === 'description')) ? 'is-invalid' : '' %>" 
                                            rows="3" 
                                            placeholder="e.g. Details about the service..."><%= locals.oldData ? oldData.description : '' %></textarea>

                                    <% if (locals.errors) { %>
                                        <% let error = errors.find(e => e.path === 'description'); %>
                                        <% if (error) { %>
                                            <div class="invalid-feedback"><%= error.msg %></div>
                                        <% } %>
                                    <% } %>

                                    <div id="serviceDescriptionHelp" class="form-text text-end">Max 100 characters</div>
                                </div>

                                <!-- SELECT HTML FORM WITH PRICING OPTIONS (Pricing Type) -->
                                <div class="mb-3">
                                    <label for="pricingType" class="form-label">Pricing Type</label>
                                    <select class="form-select <%= (locals.errors && errors.find(e => e.path === 'pricing_type')) ? 'is-invalid' : '' %>" 
                                            id="pricingType" 
                                            name="pricing_type" required>
                                        <option value="hourly" <%= (locals.oldData && oldData.pricing_type === 'hourly') ? 'selected' : '' %>>Hourly</option>
                                        <option value="fixed" <%= (locals.oldData && oldData.pricing_type === 'fixed') ? 'selected' : '' %>>Fixed</option>
                                    </select>

                                    <% if (locals.errors) { %>
                                        <% let error = errors.find(e => e.path === 'pricing_type'); %>
                                        <% if (error) { %>
                                            <div class="invalid-feedback"><%= error.msg %></div>
                                        <% } %>
                                    <% } %>
                                </div>
                                <!-- Base Price -  step="0.01" TO ALLOW DECIMALS IN TYPE NUMBER -->
                                <div class="mb-3">
                                    <label for="basePrice" class="form-label">Base Price (£)</label>
                                    <input type="number" step="0.01" required
                                        class="form-control <%= (locals.errors && errors.find(e => e.path === 'base_price')) ? 'is-invalid' : '' %>" 
                                        id="basePrice" 
                                        name="base_price"
                                        placeholder="0.00"
                                        value="<%= locals.oldData ? oldData.base_price : '' %>">
                                    
                                    <% if (locals.errors) { %>
                                        <% let error = errors.find(e => e.path === 'base_price'); %>
                                        <% if (error) { %>
                                            <div class="invalid-feedback"><%= error.msg %></div>
                                        <% } %>
                                    <% } %>
                                </div>

                                <button type="submit" class="btn btn-warning w-100">Add</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="text-center py-3">

    </footer>

    <!-- BOOTSTRAP SCRIPT -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>
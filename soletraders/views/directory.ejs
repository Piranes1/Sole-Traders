<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Find a Trader</title>

  <!-- BOOTSTRAP LINK -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" 
        rel="stylesheet" 
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" 
        crossorigin="anonymous">

  <!-- CSS LINK -->
  <link rel="stylesheet" href="/css/mystyle.css">

  <!-- GOOGLE FONTS LINK -->
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Allerta+Stencil&family=Notable&display=swap" rel="stylesheet">
  <!-- CHART JS SCRIPT -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <!-- STICKY HEADER USING BOOTSTRAP NAVBAR -->
  <header>
    <nav id="headBanner" class="navbar navbar-expand-lg sticky-top bg-warning">
      <!-- LOGO AND BUSINESS TITLE -->
      <div id="logoTitle" class="container-fluid">
        <a class="navbar-brand fw-bold fst-italic" href="/index">
          <img src="/images/workericon.png" alt="Logo" class="d-inline-block align-middle">
          SOLE TRADERS
        </a>
        <!-- NAVBAR TOGGLER TO HIDE QUICK LINKS IN SMALL SCREENS FOR RESPONSIVENESS AND A BETTER UX - navbar-expand-lg LOGIC HIDES BUTTON IN LARGE SCREENS -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <!-- QUICK LINKS -->
        <div class="collapse navbar-collapse" id="mainNavbar">
          <div class="navbar-nav ms-auto">
            <a class="nav-link" aria-current="page" href="/index">Home</a>
            <a class="nav-link active" href="/directory">Find a Trader!</a>
            <!-- LOGIC TO MAKE THE TRADER ZONE LINK LEAD TO PROFILE IF LOGGED IN OR TO LOGIN IF NOT -->
            <!-- LOGOUT BUTTON WILL ONLY SHOW IF LOGGED IN -->
            <% if (loggedIn) { %>
              <a class="nav-link" href="/profile"><%= trader_name %>'s Zone</a>
            <% } else { %>
              <a class="nav-link" href="/login">Trader Zone</a>
            <% } %>
            <% if (loggedIn) { %>
              <a class="nav-link" href="/logout">Logout</a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <!-- CONTAINER-DASHBOARD LISTING TRADERS - BOOTSTRAP ACCORDION WITH FILTERS AND CHART BY TRADER TYPE - ACCORDION ALLOWS USER TO HIDE FILTERS/ANALYTICS IF NOT NEEDED -->
  <main class="container-fluid px-md-5 mt-4"> 
    <h2 class="mb-4">Available Traders</h2>
    <div class="accordion mb-5" id="directoryDashboard">
      <div class="accordion-item shadow-sm border-dark">
        <h2 class="accordion-header">
          <button class="accordion-button bg-light fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseAnalytics">
            📊 Directory Analytics & Filters
          </button>
        </h2>
        <div id="collapseAnalytics" class="accordion-collapse collapse show" data-bs-parent="#directoryDashboard">
          <div class="accordion-body">
            <div class="row g-4 align-items-center">
              <!-- FORM FOR FILTERS BY TYPE AND REGION/TOWN -->
              <div class="col-lg-7">
                <form action="/directory" method="GET" class="row g-3">
                  <div class="col-md-6">
                    <label for="trade_type" class="form-label fw-bold small">Trade Type</label>
                    <select name="trade_type" id="trade_type" class="form-select" onchange="this.form.submit()">
                      <option value="">All Trades</option>
                      <% tradeOptions.forEach(option => { %>
                        <option value="<%= option %>" <%= currentTrade === option ? 'selected' : '' %>>
                          <%= option %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label for="region" class="form-label fw-bold small">Region/Town</label>
                    <select name="region" id="region" class="form-select" onchange="this.form.submit()">
                      <option value="">All Regions</option>
                      <% regionOptions.forEach(option => { %>
                        <option value="<%= option %>" <%= currentRegion === option ? 'selected' : '' %>>
                          <%= option %>
                        </option>
                      <% }) %>
                    </select>
                  </div>
                  <!-- Button to reset filters -->
                  <div class="col-12 mt-3">
                    <a href="/directory" class="btn btn-sm btn-outline-secondary">Reset Filters</a>
                  </div>
                </form>
              </div>

              <div class="col-lg-5 text-center border-start">
                <span class="text-muted small fw-bold d-block mb-2">Trade Distribution</span>
                <div class="chart-container">
                   <!-- Using data- attribute to pass trader data into canvas chart -->
                  <canvas id="tradeDoughnutChart" 
                    data-traders="<%= JSON.stringify(traders) %>" 
                    data-current-trade="<%= currentTrade %>"
                    data-current-region="<%= currentRegion %>">
                  </canvas>
                </div>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- TABLE-RESPONSIVE BOOTSTRAP UTILITY CLASS FOR RESPONSIVENESS IN MOBILE/SMALL SCREENS -->
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="bg-warning text-dark border-bottom border-dark">
          <tr>
            <th scope="col">Name</th>
            <th scope="col">Type</th>
            <th scope="col">Region/Town</th>
            <th scope="col">Average Rating</th>
          </tr>
        </thead>
        <!-- Logic to handle empty results -->
        <tbody class="table-group-divider">
          <% if (traders && traders.length > 0) { %>
            <% traders.forEach(trader => { %>
              <tr>
                <th scope="row">
                  <a href="/traderinfo/<%= trader.trader_id %>" class="text-decoration-none">
                    <%= trader.trader_name %>
                  </a>
                </th>  
                <td><%= trader.trade_type %></td>
                <td><%= trader.region %></td>
                <td>
                  <!-- Logic to use unicode star character to display average rating with one decimal place -->
                  <% if (trader.average_rating) { %>
                    <span class="text-warning">
                      ★ <%= Number(trader.average_rating).toFixed(1) %> / 5
                    </span>
                  <% } else { %>
                    <span class="text-muted small">No ratings yet</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4" class="text-center py-4 text-muted">
                No traders found.
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <footer>
    
  </footer>

  <!-- BOOTSTRAP SCRIPT -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
  <!-- CHART JS SCRIPT (to make use ofdirectoryChart) -->
   <script src="/js/directoryChart.js"></script>
</body>
</html>
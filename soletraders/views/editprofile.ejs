<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trader Zone</title>

    <!-- BOOTSTRAP LINK -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <!-- CSS LINK -->
    <link rel="stylesheet" href="/css/mystyle.css">

    <!-- BOOTSTRAP ICONS LINK -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- GOOGLE FONTS LINK -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Allerta+Stencil&family=Notable&display=swap" rel="stylesheet">
</head>

<body>
    <!-- STICKY HEADER USING BOOTSTRAP NAVBAR -->
    <header>
        <nav id="headBanner" class="navbar navbar-expand-lg sticky-top bg-warning">
            <!-- LOGO AND BUSINESS TITLE -->
            <div id="logoTitle" class="container-fluid">
                <a class="navbar-brand fw-bold fst-italic" href="/index">
                    <img src="/images/workericon.png" alt="Logo" class="d-inline-block align-middle">
                    SOLE TRADERS
                </a>
                <!-- NAVBAR TOGGLER TO HIDE QUICK LINKS IN SMALL SCREENS FOR RESPONSIVENESS AND A BETTER UX - navbar-expand-lg LOGIC HIDES BUTTON IN LARGE SCREENS -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <!-- QUICK LINKS -->
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <div class="navbar-nav ms-auto">
                        <a class="nav-link" aria-current="page" href="/index">Home</a>
                        <a class="nav-link" href="/directory">Find a Trader!</a>
                        <!-- LOGIC TO MAKE THE TRADER ZONE LINK LEAD TO PROFILE IF LOGGED IN OR TO LOGIN IF NOT -->
                        <!-- LOGOUT BUTTON WILL ONLY SHOW IF LOGGED IN -->
                        <% if (loggedIn) { %>
                            <a class="nav-link active" href="/profile">
                                <%= trader_name %>'s Zone
                            </a>
                        <% } else { %>
                            <a class="nav-link active" href="/login">Trader Zone</a>
                        <% } %>
                        <% if (loggedIn) { %>
                            <a class="nav-link" href="/logout">Logout</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main>
        <!-- CONTAINER WITH ONE CARDS: PROFILE UPDATE FORM -->
        <div class="container pt-5">
            <!-- CARD WITH PROFILE FORM -->
            <div class="row justify-content-center">
                <div class="col-md-10 col-lg-8">
                    <div class="card shadow-sm mb-4">
                        <div class="card-body">
                            <h5 class="card-title text-center mb-4">Your Trader Profile</h5>
                            <!-- Global Error Alert Box -->
                            <% if (locals.errors && errors.length > 0 && !errors[0].path) { %>
                                <div class="alert alert-danger">
                                    <%= errors[0].msg %>
                                </div>
                            <% } %>
                            <form action="/profile" method="post">
                                <!-- Trade Type -->
                               <div class="mb-3">
                                    <label for="tradeType" class="form-label">Trade Type</label>
                                    <input type="text" required
                                        class="form-control <%= (locals.errors && errors.find(e => e.path === 'trade_type')) ? 'is-invalid' : '' %>" 
                                        id="tradeType" name="trade_type"
                                        value="<%= locals.oldData?.trade_type ?? trader?.trade_type ?? '' %>">
                                    
                                    <% if (locals.errors) { %>
                                        <% let error = errors.find(e => e.path === 'trade_type'); %>
                                        <% if (error) { %>
                                            <div class="invalid-feedback"><%= error.msg %></div>
                                        <% } %>
                                    <% } %>
                                </div>
                                <!-- Region/Town -->
                                <div class="mb-3">
                                    <label for="regionTown" class="form-label">Region/Town</label>
                                    <input type="text" required
                                        class="form-control <%= (locals.errors && errors.find(e => e.path === 'region')) ? 'is-invalid' : '' %>" 
                                        id="regionTown" name="region"
                                        value="<%= locals.oldData?.region ?? trader?.region ?? '' %>">

                                    <% if (locals.errors) { %>
                                        <% let error = errors.find(e => e.path === 'region'); %>
                                        <% if (error) { %>
                                            <div class="invalid-feedback"><%= error.msg %></div>
                                        <% } %>
                                    <% } %>
                                </div>

                                <!-- Select HTML form with availability options -->
                                <div class="mb-3">
                                    <label for="availability" class="form-label">Availability</label>
                                    <select name="availability" id="availability" required
                                        class="form-select <%= (locals.errors && errors.find(e => e.path === 'availability')) ? 'is-invalid' : '' %>">
                                        
                                        <% const currentAvail = locals.oldData?.availability ?? trader?.availability; %>
                                        <option value="" <%= !currentAvail ? 'selected' : '' %>>-- Select Status --</option>
                                        <option value="available" <%= currentAvail === 'available' ? 'selected' : '' %>>Available</option>
                                        <option value="soon" <%= currentAvail === 'soon' ? 'selected' : '' %>>Available in 15-30 days</option>
                                        <option value="unavailable" <%= currentAvail === 'unavailable' ? 'selected' : '' %>>No Availability</option>
                                    </select>

                                    <% if (locals.errors) { %>
                                        <% let error = errors.find(e => e.path === 'availability'); %>
                                        <% if (error) { %>
                                            <div class="invalid-feedback"><%= error.msg %></div>
                                        <% } %>
                                    <% } %>
                                </div>
                                <!-- Bio -->
                                <div class="mb-3">
                                    <label for="bio" class="form-label">Short bio</label>
                                    <textarea name="bio" id="bio" rows="4"
                                        class="form-control <%= (locals.errors && errors.find(e => e.path === 'bio')) ? 'is-invalid' : '' %>"
                                        ><%= locals.oldData?.bio ?? trader?.bio ?? '' %></textarea>
                                    
                                    <% if (locals.errors) { %>
                                        <% let error = errors.find(e => e.path === 'bio'); %>
                                        <% if (error) { %>
                                            <div class="invalid-feedback"><%= error.msg %></div>
                                        <% } %>
                                    <% } %>
                                    <div id="bioHelp" class="form-text text-end">Max 750 characters</div>
                                </div>
                                
                                <!-- TABLE TO SELECT WEEKLY RECURRING AVAILABILITY/SCHEDULE - hr to draw horizontal line and improve UI -->
                                <hr class="my-4">
                                <h6 class="fw-bold mb-3"><i class="bi bi-calendar3"></i> Weekly Recurring Availability</h6>
                                <p class="text-muted small">Select the days you usually work and set your hours.</p>
                                <% if (locals.errors) { 
                                    let dayError = errors.find(e => e.path === 'working_days'); 
                                    if (dayError) { %>
                                        <div class="alert alert-danger py-2 small mb-3">
                                            <i class="bi bi-exclamation-octagon-fill me-2"></i>
                                            <%= dayError.msg %>
                                        </div>
                                    <% } 
                                } %>
                                <div class="table-responsive">
                                    <table class="table table-borderless align-middle">
                                        <tbody class="small">
                                            <% const days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']; %>
                                            <% days.forEach(day => { 
                                                const slot = schedule ? schedule.find(s => s.day_of_week === day) : null; 
                                            %>
                                            <tr>
                                                <td style="width: 30%;" class="fw-bold"><%= day %></td>
                                                <td>
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" name="working_days" value="<%= day %>" <%= slot ? 'checked' : '' %>>
                                                    </div>
                                                </td>
                                                <!-- Logic to handle weekly schedule validation feedback and that allows us to avoid a specific validation check for each possible day -->
                                                <td>
                                                    <input type="time" 
                                                            class="form-control form-control-sm <%= (locals.errors && errors.find(e => e.path === 'start_time_' + day)) ? 'is-invalid' : '' %>" 
                                                            name="start_time_<%= day %>" 
                                                            value="<%= slot ? slot.start_time.substring(0,5) : '09:00' %>">
                                                    
                                                    <% if (locals.errors) { 
                                                        let error = errors.find(e => e.path === 'start_time_' + day); 
                                                        if (error) { %>
                                                            <div class="invalid-feedback" style="font-size: 0.7rem;"><%= error.msg %></div>
                                                        <% } 
                                                    } %>
                                                </td>
                                                <td>
                                                    <input type="time" 
                                                        class="form-control form-control-sm <%= (locals.errors && errors.find(e => e.path === 'end_time_' + day)) ? 'is-invalid' : '' %>" 
                                                        name="end_time_<%= day %>" 
                                                        value="<%= slot ? slot.end_time.substring(0,5) : '17:00' %>">

                                                    <% if (locals.errors) { 
                                                        let error = errors.find(e => e.path === 'end_time_' + day); 
                                                        if (error) { %>
                                                            <div class="invalid-feedback" style="font-size: 0.7rem;"><%= error.msg %></div>
                                                        <% } 
                                                    } %>
                                                </td>
                                            </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>

                                <button type="submit" class="btn btn-warning mt-3 w-100">Update</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="text-center py-3">

    </footer>

    <!-- BOOTSTRAP SCRIPT -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>

</html>
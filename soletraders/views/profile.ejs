<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trader Zone</title>

  <!-- BOOTSTRAP LINK -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

  <!-- CSS LINK -->
  <link rel="stylesheet" href="/css/mystyle.css">

  <!-- BOOTSTRAP ICONS LINK -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <!-- GOOGLE FONTS LINK -->
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Allerta+Stencil&family=Notable&display=swap" rel="stylesheet">
</head>

<body>
  <!-- STICKY HEADER USING BOOTSTRAP NAVBAR -->
  <header>
    <nav id="headBanner" class="navbar navbar-expand-lg sticky-top bg-warning">
      <!-- LOGO AND BUSINESS TITLE -->
      <div id="logoTitle" class="container-fluid">
        <a class="navbar-brand fw-bold fst-italic" href="/index">
          <img src="/images/workericon.png" alt="Logo" class="d-inline-block align-middle">
          SOLE TRADERS
        </a>
        <!-- NAVBAR TOGGLER TO HIDE QUICK LINKS IN SMALL SCREENS FOR RESPONSIVENESS AND A BETTER UX - navbar-expand-lg LOGIC HIDES BUTTON IN LARGE SCREENS -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <!-- QUICK LINKS -->
        <div class="collapse navbar-collapse" id="mainNavbar"> 
          <div class="navbar-nav ms-auto">
            <a class="nav-link" aria-current="page" href="/index">Home</a>
            <a class="nav-link" href="/directory">Find a Trader!</a>
            <!-- LOGIC TO MAKE THE TRADER ZONE LINK LEAD TO PROFILE IF LOGGED IN OR TO LOGIN IF NOT -->
            <!-- LOGOUT BUTTON WILL ONLY SHOW IF LOGGED IN -->
            <% if (loggedIn) { %>
              <a class="nav-link active" href="/profile">
            <%= trader_name %>'s Zone
              </a>
            <% } else { %>
              <a class="nav-link active" href="/login">Trader Zone</a>
            <% } %>
            <% if (loggedIn) { %>
              <a class="nav-link" href="/logout">Logout</a>
            <% } %>
          </div>
        </div>
      </div>
    </nav>
  </header>

  <main >
    <!-- CONTAINER INCLUDING FOUR CARDS: PROFILE, AVG. RATING BAR, SERVICES AND BOOKINGS - EACH CARD TAKES A DIFFERENT ROW AND COLUMN -->
    <div class="container pt-5">
        <!-- EJS LOGIC TO HANDLE QUICK BUTTON FEEDBACK -->
        <div class="container mt-3">
          <% if (successMessage === 'accepted') { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
              <strong>Success!</strong> Booking has been accepted.
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% } %>

          <% if (successMessage === 'rejected') { %>
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
              <strong>Notice:</strong> Booking has been rejected.
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% } %>

          <% if (successMessage === 'deleted') { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <strong>Deleted:</strong> The service has been removed.
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% } %>

          <% if (errorMessage) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <strong>Error:</strong> Something went wrong. Please try again.
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          <% } %>
        </div>
      <!-- CARD WITH PROFILE INFO -->
      <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h5 class="card-title text-center mb-4">Your Trader Profile</h5>
              <form action="/profile" method="post">
                <div class="mb-3">
                  <label class="form-label fw-bold">Trade Type</label>
                  <p class="form-control-plaintext">
                    <%= trader.trade_type %>
                  </p>
                </div>

                <div class="mb-3">
                  <label class="form-label fw-bold">Region/Town</label>
                  <p class="form-control-plaintext">
                    <%= trader.region %>
                  </p>
                </div>

                <!-- Select HTML form with availability options -->
                <div class="mb-3">
                  <label class="form-label fw-bold">Availability</label>
                  <p class="form-control-plaintext">
                    <% if (trader.availability === 'available') { %>
                      <span class="text-dark">Available Now</span>
                    <% } else if (trader.availability === 'soon' || trader.availability === '15-30') { %>
                      <span class="text-dark">Available Soon (15-30 days)</span>
                    <% } else { %>
                      <span class="text-danger">Currently Unavailable</span>
                    <% } %>
                  </p>
                </div>
                <!-- Bio: Can't be empty or would make crash EJS because of .length calc -->
                <div class="mb-3">
                  <label class="form-label fw-bold">Bio</label>
                  <% if (trader.bio) { %>
                    <p class="form-control-plaintext <%= trader.bio.length > 300 ? 'mobile-truncate' : '' %>" 
                      onclick="this.classList.toggle('expanded')">
                        <%= trader.bio %>
                    </p>
                  <% } else { %>
                    <p class="text-muted">Tell us a bit about yourself!</p>
                  <% } %>
                </div>

                <!-- Recurring Availability/Schedule -->
                <div class="mb-3">
                  <label class="form-label fw-bold">Weekly Schedule</label>
                  <div class="d-flex flex-wrap gap-2">
                    <% if (schedule && schedule.length > 0) { %>
                      <% schedule.forEach(slot => { %>
                        <span class="badge bg-light text-dark border p-2">
                          <span class="text-warning fw-bold"><%= slot.day_of_week.substring(0,3) %>:</span> 
                          <%= slot.start_time.substring(0,5) %> - <%= slot.end_time.substring(0,5) %>
                        </span>
                      <% }) %>
                    <% } else { %>
                      <p class="text-muted small">No recurring hours set.</p>
                    <% } %>
                  </div>
                </div>

                <a href="/editprofile" class="btn btn-warning w-100">
                  <i class="bi bi-pencil"></i> Edit Profile
                </a>

              </form>
            </div>
          </div>
        </div>
      </div>
      <!-- AVERAGE RATING PROGRESS BAR - CALCULATING PERCENTAGE OF BAR FIRST -->
      <div class="row justify-content-center">
        <% let ratingPercent = (trader.average_rating || 0) / 5 * 100; %>
        <div class="col-md-10 col-lg-8">
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h5 class="card-title text-center mb-4">Average Customer Rating</h5>
              
              <div class="d-flex align-items-center justify-content-center gap-4 flex-wrap">
                <div class="display-4 fw-bold text-dark">
                  <%= trader.average_rating ? Number(trader.average_rating).toFixed(1) : '0.0' %>
                </div>

                <div class="text-start">
                  <div class="fs-3 text-warning">
                    <% for(let i=1; i<=5; i++) { %>
                      <i class="bi <%= i <= Math.round(trader.average_rating || 0) ? 'bi-star-fill' : 'bi-star' %>"></i>
                    <% } %>
                  </div>
                  <p class="mb-0 fw-bold">Current Score</p>
                  <p class="mb-0 text-muted small">Based on your customer ratings</p>
                </div>
              </div>

              <div class="mt-4 px-lg-5 text-center">
                <% if (trader.average_rating) { %>
                  <div class="progress" style="height: 12px; background-color: #e9ecef;">
                    <div class="progress-bar bg-warning" role="progressbar" 
                        style="--rating-width: <%= ratingPercent %>%; width: var(--rating-width);">
                    </div>
                  </div>
                  <div class="d-flex justify-content-between mt-2 px-1">
                    <span class="text-muted small">New Trader</span>
                    <span class="text-muted small">Top Rated</span>
                  </div>
                <% } else { %>
                  <p class="text-muted fst-italic small">No ratings yet. Complete your first job to see your progress!</p>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- TRADER SERVICES TABLE FORM INSIDE A CARD -->
      <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h5 class="card-title text-center mb-4">Your Trader Services</h5>
              <!-- Table listing all the services -->
               <div class="table-responsive">
                <table class="table align-middle">
                  <thead>
                    <tr>
                      <th scope="col">Title</th>
                      <th scope="col">Description</th>
                      <th scope="col">Pricing Type</th>
                      <th scope="col">Base Price (£)</th>
                      <th scope="col"></th> <!-- Empty column to handle update/delete buttons without a header -->
                    </tr>
                  </thead>
                  <tbody class="table-group-divider">
                    <!-- Handling the case where no services are listed -->
                    <% if (services.length===0) { %>
                      <tr>
                        <td colspan="5" class="text-center text-muted py-3">
                          You haven’t added any services yet.
                        </td>
                      </tr>

                    <% } else { %>
                      <% services.forEach(service => { %>
                        <tr>
                          <!-- Handling responsiveness in small screens, required to truncate and expand without visual glitches -->
                          <td class="fw-bold">
                            <div class="<%= service.title.length > 25 ? 'mobile-truncate' : '' %>" 
                                onclick="this.classList.toggle('expanded')">
                            <%= service.title %>
                            </div>
                          </td>
                          <!-- Handling responsiveness in small screens, required to truncate and expand without visual glitches -->
                          <td>
                            <div class="<%= service.description.length > 25 ? 'mobile-truncate' : '' %>" 
                                onclick="this.classList.toggle('expanded')">
                              <%= service.description %>
                            </div>
                          </td>
                          <td class="text-capitalize"><%= service.pricing_type %></td>
                          <td><%= service.base_price %></td>
                          <!-- Edit and Delete service icons -->
                          <td>
                            <div class="d-flex gap-2">
                              <a href="/editservice/<%= service.service_id %>" class="btn btn-sm btn-warning ed-del-service-btn">
                                <i class="bi bi-pencil"></i>
                              </a>

                              <form action="/deleteservice/<%= service.service_id %>" method="POST">
                                <button type="submit" class="btn btn-sm btn-danger ed-del-service-btn ">
                                  <i class="bi bi-trash"></i>
                                </button>
                              </form>
                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>

                    <!-- Add Service Row -->
                    <tr>
                      <td colspan="5" class="py-3">
                        <div class="d-flex align-items-center gap-2">
                          <a href="/addservice" class="btn btn-warning btn-sm w-100">
                            <i class="bi bi-plus-lg"></i>Add a Service
                          </a>
                        </div>
                      </td>
                    </tr>
                  </tbody>
                </table>
               </div>
            </div>
          </div>

        </div>
      </div>

      <!-- CARD WITH BOOKINGS - SINCE THERE ARE MANY FIELDS THIS COULD IMPACT UX, A MODAL WILL BE USED TO IMPROVE UX AND AVOID HORIZONTAL SCROLLING -->
      <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
          <div class="card shadow-sm mb-4">
            <div class="card-body">
              <h5 class="card-title text-center mb-4">Your Bookings</h5>
              <form method="GET" action="/profile">
                <!-- The select triggers the onchange event which will filter the bookings -->
                <select name="status" class="form-select form-select-sm" onchange="this.form.submit()">
                  <option value="all" <%= currentStatus === 'all' ? 'selected' : '' %>>All</option>
                  <option value="pending"<%= currentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
                  <option value="accepted" <%= currentStatus === 'accepted' ? 'selected' : '' %>>Accepted</option>
                  <option value="rejected" <%= currentStatus === 'rejected' ? 'selected' : '' %>>Rejected</option>
                </select>
              </form>
              <!-- Table listing bookings -->
              <div class="table-responsive">
                <table class="table align-middle">
                  <thead>
                    <tr>
                      <th scope="col">Customer Name</th>
                      <!--<th scope="col">Customer E-Mail</th>-->
                      <th scope="col">Service</th>
                      <!--<th scope="col">Description</th>-->
                      <th scope="col">Requested Start Date</th>
                      <th scope="col">Requested Start Time</th>
                      <th scope="col">Status</th>
                      <th scope="col"></th> <!-- Empty column to handle buttons without a header -->

                    </tr>
                  </thead>
                  <tbody class="table-group-divider">
                    <!-- Handling the case where no services are listed -->
                    <% if (bookings.length === 0) { %>
                      <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                          <i class="bi bi-info-circle d-block mb-2 fs-4"></i>
                          <% if (currentStatus === 'all') { %>
                            You currently have no bookings.
                          <% } else { %>
                            No <strong><%= currentStatus %></strong> bookings found.
                          <% } %>
                        </td>
                      </tr>

                    <% } else { %>
                      <% bookings.forEach(booking=> { %>
                        <tr>
                          <td>
                            <%= booking.client_name %>
                          </td>
                          <td>
                            <%= booking.service_title %>
                          </td>
                          <td>
                            <%= booking.requested_date.split('T')[0] %>
                          </td>
                          <td>
                            <%= booking.requested_start_time.substring(0, 5) %>
                          </td>
                          <td class="text-capitalize">
                            <%= booking.status %>
                          </td>
                          <td>
                            <!-- Horizontal row to keep icons in same row -->
                            <div class="d-flex gap-2">
                              <!-- Accept booking with a tick icon-->
                              <form action="/acceptbooking/<%= booking.booking_id %>" method="POST">
                                <button type="submit" class="btn btn-sm btn-warning flex-grow-1 book-btn">
                                  <i class="bi bi-check-lg"></i>
                                </button>
                              </form>
                              <!-- Decline booking with an X icon-->
                              <form action="/rejectbooking/<%= booking.booking_id %>" method="POST">
                                <button type="submit" class="btn btn-sm btn-danger flex-grow-1 book-btn">
                                  <i class="bi bi-x-lg"></i>
                                </button>
                              </form>
                              <!-- Button to open modal, so that trader can see more information about booking-->
                              <button type="button" class="btn btn-sm btn-info book-btn" data-bs-toggle="modal"
                                data-bs-target="#bookingModal" data-client-name="<%= booking.client_name %>"
                                data-client-email="<%= booking.client_email %>"
                                data-service-title="<%= booking.service_title %>"
                                data-description="<%= booking.job_description %>"
                                data-requested-date="<%= booking.requested_date %>"
                                data-requested-time="<%= booking.requested_start_time %>"
                                data-created-at="<%= booking.created_at %>">
                                <i class="bi bi-eye"></i>
                              </button>

                            </div>
                          </td>
                        </tr>
                      <% }) %>
                    <% } %>

                  </tbody>
                </table>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- HTML REQUIRED FOR THE MODAL PLACED IN A TOP-LEVEL POSITION, FOLLOWING BOOTSTRAP DOCUMENTATION-->
    <div class="modal fade" id="bookingModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <!-- Modal header -->
          <div class="modal-header">
            <h5 class="modal-title">Booking Details</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <!-- Modal body -->
          <div class="modal-body">
            <p><strong>Name:</strong> <span id="modalClientName"></span></p>
            <p><strong>Email:</strong> <span id="modalClientEmail"></span></p>
            <p><strong>Service:</strong> <span id="modalServiceTitle"></span></p>
            <p><strong>Description:</strong> <span id="modalDescription"></span></p>
            <p><strong>Date:</strong> <span id="modalRequestedDate"></span></p>
            <p><strong>Time:</strong> <span id="modalRequestedTime"></span></p>
            <p><strong>Created:</strong> <span id="modalCreatedAt"></span></p>
          </div>
          <!-- Modal footer -->
          <div class="modal-footer">
            <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          </div>

        </div>
      </div>
    </div>
  </main>

  <footer class="text-center py-3">

  </footer>

  <!-- BOOTSTRAP AND JS SCRIPT -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
    crossorigin="anonymous"></script>
  <script src="/js/bookingModal.js"></script>
</body>
</html>